# LocalHomeApp example environment
LOCAL_HOME_APP_ENV=development
LOCAL_HOME_APP_DATA_ROOT=/absolute/path/to/localhomeapp-data
LOCAL_HOME_APP_DATABASE_PATH=/absolute/path/to/localhomeapp-data/local_home_app.sqlite
LOCAL_HOME_APP_TELEGRAM_BOT_TOKEN=
LOCAL_HOME_APP_TELEGRAM_MAIN_CHAT_ID=
LOCAL_HOME_APP_TELEGRAM_WORKERS_CHAT_ID=
LOCAL_HOME_APP_TELEGRAM_ALERTS_CHAT_ID=
LOCAL_HOME_APP_OCR_PRIMARY_ENGINE=apple_vision
LOCAL_HOME_APP_OCR_FALLBACK_ENGINE=tesseract
LOCAL_HOME_APP_TESSERACT_BINARY=tesseract
LOCAL_HOME_APP_LOG_LEVEL=INFO
